{
  "name": "obsidian-simplified-traditional-search",
  "version": "2.1.2",
  "description": "Obsidian plugin for Simplified/Traditional Chinese search unification",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "chinese",
    "search",
    "cjk"
  ],
  "author": "",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.24.0",
    "obsidian": "^1.5.0",
    "tslib": "^2.6.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  }
}
